# =============================================================================
# MaxClaw — config.yaml v3.1 (VORSCHLAG, NICHT AKTIV)
# =============================================================================
# Integrierte Härtungen auf Basis security-audit-2026-07-04.md.
# Wartet auf Bastis Review, bevor sie nach config/config.yaml übernommen wird.
#
# Änderungen ggü. v3.0 (Repo-Vorlage):
#   1. write_paths verschärft: nur 4 Pfade + ~/logs/
#   2. permissions.terminal: curl/wget hinzu (P0-Pattern), rm eingeschränkt
#   3. permissions.skills: Skill-Whitelist mit Tool-Berechtigungen
#   4. cron.approval_mode: 'safe' default, 'smart' opt-in für Watchdogs
#   5. network.isolation: Egress-Allowlist + DNS-Only
#   6. limits.*: Rate-Limits pro Modell + globale Caps
#   7. observability.audit_script: Verweis auf ~/bin/maxclaw-security-audit.sh
#   8. P0-Mitigationen: secrets.backend-Doku, watchdog-cooldown
# =============================================================================

# --- Modell-Routing: verschiedene Modelle für verschiedene Aufgaben ----------
models:
  main:
    provider: openrouter
    model: moonshotai/kimi-k2.5
    monthly_limit_eur: 20         # hart (P1-Fix)
    fallback: openrouter/free

  heavy:
    provider: openrouter
    model: anthropic/claude-opus-4.6
    monthly_limit_eur: 50

  heartbeat:
    provider: openrouter
    model: google/gemini-flash     # billig-erzwungen
    monthly_limit_eur: 1.0         # Watchdog-Budget klein halten

  subagent:
    provider: openrouter
    model: google/gemini-flash
    monthly_limit_eur: 5

# --- Berechtigungen: DEFAULT-DENY --------------------------------------------
permissions:
  default: deny

  tools:
    terminal:
      enabled: true
      allow:
        # Git read+stage
        - "git status"
        - "git diff*"
        - "git log*"
        - "git add*"
        - "git commit*"
        # Read-only filesystem
        - "ls*"
        - "cat*"
        - "grep*"
        - "find*"
        - "head*"
        - "tail*"
        - "wc*"
        # GreyHack-Build (ohne -u, dokumentiert in TOOLS.md)
        - "greybel build*"
        # Audit-Skript
        - "~/bin/maxclaw-security-audit.sh"
      deny:
        # Killer-Patterns (P0)
        - "rm -rf*"
        - "rm -fr*"
        - "git push* main*"
        - "git push* origin main*"
        - "sudo*"
        - "su -"
        - "su root"
        # Blind-Pipe-to-Shell
        - "curl* | *sh"
        - "curl* | bash"
        - "wget* | *sh"
        - "wget* | bash"
        # Datenträger
        - "dd of=/dev/*"
        - "mkfs.*"
        # Permission-Eskalation
        - "chmod -R 777*"
        - "chmod 777*"
        - "chown -R*"
        # Force-Push & destruktiv
        - "git push* -f*"
        - "git push* --force*"
        - "git reset --hard*"
        - "git clean -fd*"
        # System-Service-Manipulation
        - "systemctl disable*"
        - "systemctl stop*"
        - "systemctl mask*"

    file:
      enabled: true
      # VERSCHÄRFT: nur notwendige Pfade
      write_paths:
        - "~/greyhack-tools/"          # Build-Artefakte
        - "~/docs/"                    # System-Docs
        - "~/.openclaw/agent/"         # Agent-Self (nur eigener Bereich)
        - "~/logs/"                    # Audit-Logs (NEU in v3.1)
      read_paths:
        - "~/"                         # Lesen überall ok, schreiben nur in write_paths
      max_file_size_mb: 50            # Verhindert versehentliches Riesenkopieren
      no_symlinks_in:
        - "~/.ssh"
        - "~/.gnupg"
        - "/etc"

    browser:
      enabled: false                  # Prompt-Injection-Risiko (docs/07)
    web_search:
      enabled: true
      # Nur Suchen, kein Surfen / Klicken
      max_results_per_query: 10

  # Skill-Whitelist (NEU in v3.1)
  # Welcher Skill darf welche Tools?
  skills:
    greyhack:
      allowed_tools: [terminal, file.read]
      write_paths: ["~/greyhack-tools/"]
      max_calls_per_hour: 20
    greyhack-sandbox:
      allowed_tools: [terminal, file.write]
      write_paths: ["~/greyhack-tools/build/"]
      network: deny                   # niemals raus
      max_calls_per_hour: 10
    greyscript-compiler-debugging:
      allowed_tools: [terminal.read]
      write_paths: []
      max_calls_per_hour: 5
    github-ops:
      allowed_tools: [terminal, file.read]
      write_paths: ["~/docs/system/"]
      max_calls_per_hour: 10
      # Verboten via Deny-Liste auf gleicher Ebene:
      forbidden_subcommands:
        - "gh repo delete"
        - "gh pr merge --*"
        - "git push -f"
    maxclaw-session-manager:
      allowed_tools: [file]
      write_paths: ["~/.openclaw/sessions/"]
    telegram-notifier:
      allowed_tools: [network.telegram]
      max_messages_per_hour: 10
      max_messages_per_day: 30
    project-doc-sync:
      allowed_tools: [file]
      write_paths: ["~/docs/system/"]
    knowledge-distiller:
      allowed_tools: [file.read]
      write_paths: []
    sandbox-snapshot:
      allowed_tools: [file]
      write_paths: ["~/greyhack-tools/build/.snapshots/"]
    sqlite-reader:
      allowed_tools: [file.read]
      write_paths: []
    bash-script-builder:
      allowed_tools: [file]
      write_paths: ["~/bin/"]
      require_audit_trail: true        # jede Änderung wird geloggt
      max_calls_per_day: 5

# --- Bestätigungspflicht (Human-in-the-loop) ---------------------------------
confirmations:
  require_before:
    - send_message
    - publish
    - delete_outside_workspace
    - git_push_main
    - skill_install                  # NEU: jede Skill-Installation erfordert OK
    - config_change                  # NEU: jede Änderung an dieser YAML
    - write_outside_write_paths      # NEU: Verstoß sofort stoppen + fragen

# --- Secrets -----------------------------------------------------------------
secrets:
  # NEU: explizite Wahl — Hermes-nativ vs SecretRef (siehe P0-Fund)
  backend: hermes-native             # P0-Empfehlung Variante A
  path: "~/.hermes/auth.json"        # 0600 — durch Audit verifiziert
  rotation_interval_days:
    openrouter: 90
    telegram_bot: 180
    gh_token: 90
    gateway_token: 180
  never_in:
    - "config.yaml"                  # wir selbst!
    - "MEMORY.md"
    - "*.log"
    - "Telegram-Chat"

# --- Gateway / Netzwerk -----------------------------------------------------
gateway:
  bind: "127.0.0.1"                   # NUR localhost
  port: 18789
  require_token: true
  tls: false                          # loopback = ok

# --- Network-Isolation (NEU in v3.1) -----------------------------------------
network:
  isolation: allowlist
  egress_allowlist:
    - host: "openrouter.ai"
      ports: [443]
      reason: "Modell-API"
    - host: "api.telegram.org"
      ports: [443]
      reason: "Basti-Benachrichtigungen"
    - host: "api.github.com"
      ports: [443]
      reason: "gh CLI"
    - host: "github.com"
      ports: [443]
      reason: "gh web"
    - host: "raw.githubusercontent.com"
      ports: [443]
      reason: "Skill-Updates (vertrauenswürdig)"
  deny:
    - all_http_port_80               # Klartext verboten
    - all_other_hosts                # Default-Deny
  require_explicit_allowlist_change: true

# --- Channels ---------------------------------------------------------------
channels:
  telegram:
    enabled: true
    home_chat_id: "7222661188"
    rate_limits:
      per_hour: 10
      per_day: 30

# --- Automatisierung --------------------------------------------------------
automation:
  heartbeat:
    interval_minutes: 30
    model: heartbeat                  # billig-erzwungen
  cron:
    enabled: true
    # NEU: Approval-Mode (GreyHack: Watchdog silent, sicher = manuell)
    approval_mode: safe               # default — alle Jobs manuell abgehakt
    smart_allowlist:                  # opt-in Watchdogs
      - greyhack-ci-watch             # silent bei OK, Alert bei ROT
      - github-pr-monitor             # silent wenn keine PRs offen
    jobs_user: bratan                 # IMMER User-Cron, niemals root
    max_modifications_per_day: 2

# --- Limits / Rate-Limits (NEU in v3.1) --------------------------------------
limits:
  global:
    max_tool_calls_per_minute: 30
    max_telegram_messages_per_day: 30
    cooldown_seconds_after_p0_alert: 1800   # verhindert Alert-Sturm
  models: {}  # wird oben schon via monthly_limit_eur abgedeckt

# --- Observability (NEU in v3.1) ---------------------------------------------
observability:
  audit_script: "~/bin/maxclaw-security-audit.sh"
  audit_log: "~/logs/maxclaw-security-audit-LAST.json"
  audit_history_keep: 30
  on_p0:
    action: log_only                  # Hook für Telegram-Alert, NICHT auto
    hook: "manual_review_required"
  on_p1:
    action: daily_digest
  on_p2:
    action: log_only

# --- Audit-Metadaten --------------------------------------------------------
metadata:
  schema_version: "3.1"
  audit_source: "security-audit-2026-07-04.md"
  awaiting_review_by: "Basti"
  review_status: proposed
  notes: |
    Diese Config ist die v3.1-Härtung des Repo-Originals.
    NICHT direkt nach ~/.hermes/config.yaml kopieren — Basti muss P0-Fragen
    beantworten und das Review abnehmen (siehe security-audit-2026-07-04.md §5).